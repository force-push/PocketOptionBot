# ArgusSentinel — FUNCTIONAL CONFIG (committed, git-tracked)
# Strategy parameters, risk settings, feature flags. NO secrets here.
# Credentials live in .env.secrets (gitignored).

SHADOW_RECORD_MODE=true

# ── Trading Mode: DEMO or LIVE (MUST be DEMO by default) ──
TRADE_MODE=DEMO
DASHBOARD_ENABLED=true
DASHBOARD_HOST=0.0.0.0

# ── Risk Management ──
DRY_RUN=false
MAX_OPEN_TRADES=6
TRADE_STAGGER_SECONDS=0         # 0 for 5s scalping (sequential scan already spaces placements)
MIN_BALANCE_MULTIPLIER=5
MAX_TRADES_PER_HOUR=240
MAX_DAILY_LOSS_USD=50.0
COOLDOWN_AFTER_LOSS_SECONDS=5
# Per-pair post-loss cooldown (2026-06-15): after a pair loses, skip re-entering
# it for 60s (poll loop + FocusSession trade other pairs meanwhile). Data: trades
# <60s after a loss on a pair ~42% WR; skipping flipped allowed-set backtest
# -$471 -> +$107. Tune via tools/analyze_failures.py.
POST_LOSS_PAIR_COOLDOWN_SECONDS=30

# ── v2 Navigation & Decision Settings ──
STAKE_AMOUNT=1.5                   # 2026-06-20 20:25 ACST: corrected 2.0→1.5 — Martingale ladder: $1.50→$3.30→$7.26 (max)
DEFAULT_EXPIRY_SECONDS=5           # 5s scalping (snapped to nearest allowed)
# Shadow expiry experiment: each real signals trade is replicated (demo only,
# shadow=True) at these durations to compare win rate across expiries. []=off.
SHADOW_EXPIRY_SECONDS=[]

# 5s timeframe shadow track (2026-06-16): fetches 5s candles per pair per cycle,
# evaluates with flip_levers_5s.json, places shadow trades at each expiry.
# HARD GUARD: silently ignored when TRADE_MODE=LIVE. Research only.
SHADOW_TF5S_ENABLED=false              # 2026-06-20: disabled — 246 samples at 44.7% WR, confirmed loser
SHADOW_TF5S_EXPIRY_SECONDS=[15,30]

# ── SuperTrend-flip strategy (2026-06-14) ──
STRATEGY_MODE=flip                 # flip | confluence
# Pair allowlist — empty means trade ALL active pairs above MIN_PAYOUT_PCT.
# Set to a JSON list to restrict to specific symbols (e.g. for A/B testing).
# Pair whitelist updated 2026-06-20 — expanded to all 92% payout positive-EV pairs (flip era, n≥25).
# Tier 1 (n≥60, WR≥53%): EURNZD(56.5%), OMRCNY(54.8%), SARCNY(54.7%), GBPAUD(54.5%), MADUSD(53.7%), USDBRL(53.7%)
# Tier 2 (n≥25, WR≥55%, 7-day review): MARA(59.3%), MCD(58.6%), PFE(57.6%), GBPJPY(57.1%), TSLA(56.2%), CADCHF(55.6%), JODCNY(55.3%)
# Carried forward: AUDUSD(52.9%, n=227 — marginal but large sample, keep monitoring)
# Removed: DOGE (50.9% — negative EV, n=275)
# 2026-06-20 20:24 ACST: WHITELIST REVERTED — fixed 9-pair list was too restrictive (0-1 pairs above payout floor at any given time)
# Whitelist needs dynamic payout-aware implementation; static list + payout floor = dead bot at off-peak hours
# Active approach: open universe at 92% payout + 23-pair blocklist (see BLOCKED_PAIRS below)
ALLOWED_PAIRS=[]
ALLOWED_PAIR_REGEX=
ONE_OPEN_TRADE_PER_PAIR=true       # one trade per pair; re-enter only after it resolves
ST_PERIOD=10                       # SuperTrend ATR period
ST_MULTIPLIER=3.0                  # SuperTrend band multiplier
FLIP_ADX_MIN=22                    # min ADX to confirm a fresh flip
TREND_ADX_MIN=25                   # higher ADX bar for trend continuation
TREND_REQUIRE_ADX_RISING=true      # continuation needs ADX rising
TREND_ATR_DISTANCE_MIN=0.5         # continuation: price ≥ this×ATR from ST band
FLIP_WINDOW_BARS=3                 # treat flip as fresh if trend started ≤N bars ago
CANDLE_FETCH_CONCURRENCY=3         # parallel history(1) prefetch cap (evaluate more often)
STREAMING_ENABLED=true             # event-driven flip catcher: ~0.5s detection lag vs ~6s poll
FOCUS_SESSION_ENABLED=true         # focus-pair session: lock onto best payout pair, trade N flips, rotate
FOCUS_SESSION_TRADES=10            # trades per pair before rotating
FOCUS_FX_ONLY=false                # 2026-06-16: allow DOGE_otc (54.9% WR, n=173) — regex controls universe now
FOCUS_PAYOUT_FLOOR=88              # 88% floor: BE 53.2% — needed to surface AUDUSD/EURNZD pre-London; 90% still too restrictive
FOCUS_MIN_TICK_RATE=2.0            # min avg ticks/bar; illiquid pairs cooled off 5min
STREAMING_PAIRS=["AUDUSD_otc","EURNZD_otc","OMRCNY_otc","SARCNY_otc"]   # 2026-06-20: blocked AUDNZD/NZDUSD/AUDCHF (WR<38%), replaced with top performers
SHADOW_ADX_REGIME_MIN_CONF=0.60    # 2026-06-20: enabled — collecting adx_conf ≥0.60 (showing 55-66% WR at n=24-40, need 200+/bucket)
SHADOW_FLIP_SKIP_ENABLED=false     # 2026-06-20: disabled — 8,839 samples at 48.5% WR, confirmed loser
# Pair-selection win-rate gate. 0.0 DISABLES it (testing/capture — no trades).
# 2026-06-09: data (n=116) showed bot_win_rate>=0.80 -> 54.3% WR vs 41.7% at 0.7-0.8.
# This is the single biggest lever; re-enabled at 0.80 (was the "82% rule").
PAIR_SELECT_MIN_WIN_RATE=0.70
# Chronic losers — statistically confirmed, never trade (WR<44%, n≥30, flip-era 2026-06-09+):
# USDJPY(40.0%,n=50) GBPUSD(39.3%,n=56) USDCAD(37.0%,n=46) NZDJPY(39.6%,n=53)
# USDBDT(39.6%,n=53) USDINR(37.9%,n=58) YERUSD(37.7%,n=61) NGNUSD(41.4%,n=58)
# IRRUSD(42.6%,n=54) AUDNZD(41.7%,n=48) AUDCAD(41.7%,n=36) USDMYR(41.3%,n=46)
# EURCHF(43.2%,n=88) UAHUSD(43.2%,n=44) AUDCHF(38.2%,n=34) ETHUSD(37.5%,n=32)
# VIX(33.3%,n=30) BNB-USD(32.4%,n=34)
# 2026-06-20 20:14 ACST: added AVAX(41.9%,n=43), VISA(43.6%,n=39), LINK(31.4%,n=35), ADA-USD(35.5%,n=31), #INTC(38.5%,n=26)
BLOCKED_PAIRS=["USDJPY_otc","GBPUSD_otc","USDCAD_otc","NZDJPY_otc","USDBDT_otc","USDINR_otc","YERUSD_otc","NGNUSD_otc","IRRUSD_otc","AUDNZD_otc","AUDCAD_otc","USDMYR_otc","EURCHF_otc","UAHUSD_otc","AUDCHF_otc","ETHUSD_otc","VIX_otc","BNB-USD_otc","AVAX_otc","VISA_otc","LINK_otc","ADA-USD_otc","#INTC_otc"]
MIN_PAYOUT_PCT=92                  # 2026-06-20 20:24 ACST: restored to 92% — whitelist reverted (see below); open universe + blocklist approach resumed
# Performance cooldown — bench a pair for 12h if rolling 3h WR drops below threshold
PERF_COOLDOWN_MAX_WR=0.50          # 2026-06-20 20:14 ACST: raised 0.48→0.50 — bench anything under 50% rolling 3h WR (was 0.48)
PERF_COOLDOWN_MIN_TRADES=5         # 2026-06-20: raised 3→5 — avoid benching on 1-2 unlucky trades
PERF_COOLDOWN_HOURS=1.0            # 2026-06-20: reduced 12h→1h — pairs return faster after a rough patch
PREDICTION_SOURCE=signals           # signals=payout-first loop (Option A) | broker_bot=original
MAX_PAIRS_PER_CYCLE=0              # 0=all above floor; set 10-15 to limit scan size
MIN_EXPECTED_VALUE=0.0             # Min EV per trade (0=break-even gate) — EV gate blocks any pair/direction below 52.1% WR
MIN_EV_SAMPLES=10                  # 2026-06-20: lowered 15→10 — EV gate kicks in faster for new pairs in open universe
# ── Martingale stake doubling (2026-06-20) ──────────────────────────────────
# After N consecutive losses on a pair, doubles stake for next trade on that pair.
# Resets to STAKE_AMOUNT on any win. Only doubles when pair live WR >= min_pair_wr
# AND n_samples >= min_wr_samples. Cap: base × 2^max_level (default = 8× at $8).
# Enable only after validating base strategy in demo. Disable = 0 exposure change.
MARTINGALE_ENABLED=true
MARTINGALE_MULTIPLIER=2.2          # Stake multiplier per loss level (2.0=double, 2.2=2.2× each level)
MARTINGALE_MAX_LEVEL=2             # Max scaling levels: level 2 at 2.0× = 4× base stake
MARTINGALE_MIN_PAIR_WR=0.521      # 2026-06-20 20:14 ACST: raised 0.4→0.521 — only double on pairs above break-even; was doubling on chronic losers
MARTINGALE_MIN_WR_SAMPLES=3      # Require ≥10 resolved trades on pair before scaling
MARTINGALE_MIN_SESSION_TRADES=3       # Require ≥3 resolved trades this session before doubling
CLICK_TRADE_ANYWAY=true            # Auto-dismiss the low-balance nag screen
DECISIONS_LOG_PATH=data/decisions.jsonl

# ── TA Signal Engine ──
USE_REAL_OHLC=true                  # Real wicks via history() — justified at 60-300s shadow expiries
CANDLE_INTERVAL_SECONDS=1           # 1s candles for 5s scalping (tick-line precision; history() serves ~800)
HISTORY_LENGTH=100                  # Number of candles to fetch for TA
MIN_SIGNAL_AGREEMENT=2              # Min signals agreeing on same direction (1–5)
MIN_CONFLUENCE_SCORE=0.20           # Weighted confluence score floor — OPTIMIZED actual filtering

# ── Legacy gate thresholds (used by the v1 signal_gate, not v2) ──
MIN_CHANNEL_WIN_RATE=0.80
MIN_TRACKED_WIN_RATE=0.55
MIN_TRACKED_SAMPLES=20
SHADOW_TRADE_BLOCKED_HOURS=true
# Fade disabled 2026-06-13: confirmed loser since-5am (shadow 46.9% / real 42.9% WR, -$56). 0=off.
SHADOW_FADE_MIN_AGREE=0
