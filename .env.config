# ArgusSentinel — FUNCTIONAL CONFIG (committed, git-tracked)
# Strategy parameters, risk settings, feature flags. NO secrets here.
# Credentials (PO_SSID, Telegram) live in .env.secrets (gitignored).

SHADOWS_ENABLED=false           # 2026-06-23: master kill-switch — no shadow trades of any kind
SHADOW_RECORD_MODE=false

# ── Trading Mode: DEMO or LIVE (MUST be DEMO by default) ──
TRADE_MODE=DEMO
DASHBOARD_ENABLED=true
DASHBOARD_HOST=127.0.0.1

# ── Risk Management ──
DRY_RUN=false
MAX_OPEN_TRADES=6
TRADE_STAGGER_SECONDS=0         # 0 for 5s scalping (sequential scan already spaces placements)
MIN_BALANCE_MULTIPLIER=5
MAX_TRADES_PER_HOUR=240
MAX_DAILY_LOSS_USD=50.0
COOLDOWN_AFTER_LOSS_SECONDS=5
# Per-pair post-loss cooldown: after a pair loses, skip re-entering for 30s.
# Data: trades <60s after a pair loss ~42% WR; skip flipped allowed-set backtest
# -$471 -> +$107. Tune via tools/analyze_failures.py.
POST_LOSS_PAIR_COOLDOWN_SECONDS=30

# ── v2 Decision Settings ──
STAKE_AMOUNT=1.5                   # base stake $1.50; level-1 martingale ladder $1.50→$3.30
DEFAULT_EXPIRY_SECONDS=5           # 5s scalping (snapped to nearest allowed)
SHADOW_EXPIRY_SECONDS=[]           # []=off; set e.g. [30,60] for expiry comparison shadows
SHADOW_TF5S_ENABLED=false          # 2026-06-20: disabled — 246 samples at 44.7% WR, confirmed loser
SHADOW_TF5S_EXPIRY_SECONDS=[15,30]
CLICK_TRADE_ANYWAY=true            # Auto-dismiss the low-balance nag screen
DECISIONS_LOG_PATH=data/decisions.jsonl

# ── SuperTrend-flip strategy (2026-06-14) ──
STRATEGY_MODE=flip                 # flip | confluence
ST_PERIOD=10
ST_MULTIPLIER=3.0
FLIP_ADX_MIN=22                    # min ADX to confirm a fresh flip
TREND_ADX_MIN=25                   # higher ADX bar for trend continuation
TREND_REQUIRE_ADX_RISING=true
TREND_ATR_DISTANCE_MIN=0.5         # continuation: price ≥ this×ATR from ST band
FLIP_WINDOW_BARS=3                 # treat flip as fresh if trend started ≤N bars ago

# ── Pair Selection ──
# Open universe at 92% payout floor + performance-cooldown + blocklist.
# Allowlist (ALLOWED_PAIRS) was tried 2026-06-20 but too restrictive at off-peak
# hours — 0-1 pairs above payout floor → dead bot. Blocklist approach is active.
ALLOWED_PAIRS=[]
ALLOWED_PAIR_REGEX=
ONE_OPEN_TRADE_PER_PAIR=true
MIN_PAYOUT_PCT=92
MAX_PAIRS_PER_CYCLE=0              # 0=all above floor; set 10-15 to limit scan size
PAIR_HOUR_BLOCKLIST_ENABLED=false

# Pair-selection rolling win-rate gate (bot's own tracked WR on each pair).
PAIR_SELECT_MIN_WIN_RATE=0.70

# ── Confirmed losers (WR<50%, n≥25, flip-era 2026-06-09+) ──
# Original set (various dates, all-time + flip-era overlap):
#   USDJPY(40%,n=50) GBPUSD(39%,n=56) USDCAD(37%,n=46) NZDJPY(40%,n=53)
#   USDBDT(40%,n=53) USDINR(38%,n=58) YERUSD(38%,n=61) NGNUSD(41%,n=58)
#   IRRUSD(43%,n=54) AUDNZD(42%,n=48) AUDCAD(42%,n=36) USDMYR(41%,n=46)
#   EURCHF(43%,n=88) UAHUSD(43%,n=44) AUDCHF(38%,n=34) ETHUSD(38%,n=32)
#   VIX(33%,n=30) BNB-USD(32%,n=34) AVAX(42%,n=43) VISA(44%,n=39)
#   LINK(31%,n=35) ADA-USD(36%,n=31) #INTC(39%,n=26)
#   EURGBP(49%,n=58) FDX(45%,n=51) BITB(47%,n=89) LTCUSD(49%,n=53) TNDUSD(49%,n=65)
# 2026-06-24 reassessment (n≥25, WR<50%, flip-era current data):
#   EURUSD(49.5%,n=109) AUDUSD(49.5%,n=279) GBPJPY(49.3%,n=138)
#   TON-USD(48.5%,n=68) DOGE(48.5%,n=134) #AXP(48.3%,n=58)
#   SOL-USD(48.2%,n=83) EURNZD(47.6%,n=82) USDCNH(47.2%,n=53)
#   USDCLP(44.1%,n=34) #FB(43.3%,n=60) SARCNY(41.2%,n=34) CADCHF(40.0%,n=30)
BLOCKED_PAIRS=["USDJPY_otc","GBPUSD_otc","USDCAD_otc","NZDJPY_otc","USDBDT_otc","USDINR_otc","YERUSD_otc","NGNUSD_otc","IRRUSD_otc","AUDNZD_otc","AUDCAD_otc","USDMYR_otc","EURCHF_otc","UAHUSD_otc","AUDCHF_otc","ETHUSD_otc","VIX_otc","BNB-USD_otc","AVAX_otc","VISA_otc","LINK_otc","ADA-USD_otc","#INTC_otc","EURGBP_otc","FDX_otc","BITB_otc","LTCUSD_otc","TNDUSD_otc","EURUSD_otc","AUDUSD_otc","GBPJPY_otc","TON-USD_otc","DOGE_otc","#AXP_otc","SOL-USD_otc","EURNZD_otc","USDCNH_otc","USDCLP_otc","#FB_otc","SARCNY_otc","CADCHF_otc"]

# ── Performance cooldown (dynamic pair benching) ──
PERF_COOLDOWN_MAX_WR=0.50          # bench if rolling 3h WR drops below 50%
PERF_COOLDOWN_MIN_TRADES=5
PERF_COOLDOWN_HOURS=1.0

# ── Scan / streaming ──
CANDLE_FETCH_CONCURRENCY=2         # lowered from 3 — reduces concurrent Rust WS calls (SIGSEGV mitigation)
STREAMING_ENABLED=true             # event-driven flip catcher: ~0.5s detection lag vs ~6s poll
# 2026-06-24 reassessment: updated to confirmed edge pairs (WR≥52.1%, n≥25)
# Previous: AUDUSD(49.5%), EURNZD(47.6%), SARCNY(41.2%) — all confirmed losers
STREAMING_PAIRS=["MATIC_otc","MADUSD_otc","USDRUB_otc","OMRCNY_otc"]
FOCUS_SESSION_ENABLED=true
FOCUS_SESSION_TRADES=10
FOCUS_FX_ONLY=false
FOCUS_PAYOUT_FLOOR=88
FOCUS_MIN_TICK_RATE=2.0

# ── Shadow research ──
SHADOW_ADX_REGIME_MIN_CONF=0       # collecting adx_conf data; set to 0 to capture all
SHADOW_FLIP_SKIP_ENABLED=false     # 2026-06-20: disabled — 8,839 samples at 48.5% WR, confirmed loser
SHADOW_FADE_MIN_AGREE=0            # 2026-06-13: disabled — confirmed loser

# ── EV gate ──
MIN_EXPECTED_VALUE=0.0             # 0=break-even floor (WR must clear 52.1% at 92% payout)
MIN_EV_SAMPLES=10

# ── Variable stake sizing (2026-06-23) ──
# Raises base stake on proven positive-EV pair/direction/expiry buckets.
VARIABLE_STAKE_ENABLED=true
VARIABLE_STAKE_MIN_SAMPLES=25
VARIABLE_STAKE_MIN_MULTIPLIER=0.5  # marginal proven buckets drop to half stake
VARIABLE_STAKE_MIN_EDGE=0.05       # WR ≥ break-even+5pts before scaling
VARIABLE_STAKE_FULL_EDGE=0.12      # reach max multiplier at break-even+12pts
VARIABLE_STAKE_MAX_MULTIPLIER=1.5  # max $2.25 before martingale

# ── Martingale (2026-06-20) ──────────────────────────────────────────────────
# Level-1 only. Level-2 data (n=106): 51% WR, net −$15. Level-1 (n=187): 54% WR, net +$27.
MARTINGALE_ENABLED=true
MARTINGALE_SCOPE=pair
MARTINGALE_MULTIPLIER=2.2
MARTINGALE_MAX_LEVEL=1
MARTINGALE_MIN_PAIR_WR=0.57        # only double when recent pair WR clearly above break-even
MARTINGALE_MIN_WR_SAMPLES=5
MARTINGALE_MIN_SESSION_TRADES=1

# ── TA Signal Engine ──
USE_REAL_OHLC=true
CANDLE_INTERVAL_SECONDS=1
HISTORY_LENGTH=100
MIN_SIGNAL_AGREEMENT=2
MIN_CONFLUENCE_SCORE=0.20

# ── Legacy thresholds (v1 signal_gate, kept for settings parse compat) ──
MIN_CHANNEL_WIN_RATE=0.80
MIN_TRACKED_WIN_RATE=0.55
MIN_TRACKED_SAMPLES=20
SHADOW_TRADE_BLOCKED_HOURS=false
