# PocketOption Trading Bot Configuration
# Copy this file to .env and fill in your values

# ── CDP (legacy — kept for backward compat, not in live path) ──
CDP_URL=http://localhost:9222

# ── Trading Mode: DEMO or LIVE (MUST be DEMO by default) ──
TRADE_MODE=DEMO

# ── Asset & Timing Configuration ──
ASSET=EURUSD
EXPIRY_SECONDS=60
TRADE_AMOUNT=1.0

# ── Signal Engine Settings ──
MIN_CONFLUENCE_SCORE=0.75
MAX_TRADES_PER_HOUR=10
MAX_DAILY_LOSS_USD=20.0
CANDLE_INTERVAL_SECONDS=60
HISTORY_LENGTH=100
COOLDOWN_AFTER_LOSS_SECONDS=120

# ── Risk Management ──
DRY_RUN=true
MAX_OPEN_TRADES=1
MIN_BALANCE_MULTIPLIER=5

# ── Telegram (Telethon MTProto user session) ──
# Get API_ID and API_HASH from https://my.telegram.org → "API development tools"
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Cloud/headless: generate a StringSession with tools/gen_telegram_session.py (run locally)
# then paste the output string here.  Preferred over file session for servers/containers.
TELEGRAM_SESSION_STRING=
# Local only: leave SESSION_STRING blank and set your phone instead (session saved to file)
TELEGRAM_PHONE=+1234567890
TELEGRAM_SESSION=po_session           # Telethon session file name (gitignored)
SIGNAL_BOT_USERNAME=po_broker_bot     # Telegram username of the signal bot

# ── PocketOption WebSocket API ──
# Copy the full 42["auth",{...}] string from your browser's WebSocket traffic
PO_SSID=                              # Full auth string; isDemo encoded in it

# ── Signal Quality Gating Thresholds ──
MIN_CHANNEL_WIN_RATE=0.80    # Minimum stated win rate from the signal bot (gate 1)
MIN_TRACKED_WIN_RATE=0.55    # Minimum our tracked real win rate (gate 2, after warm-up)
MIN_TRACKED_SAMPLES=20       # Min trades before gate 2 is enforced (cold-start bypass)
