# PocketOption Trading Bot Configuration
# Copy this file to .env and fill in your values

# CDP Connection
CDP_URL=http://localhost:9222

# Trading Mode: DEMO or LIVE (MUST be DEMO by default)
TRADE_MODE=DEMO

# Asset & Timing Configuration
ASSET=EURUSD
EXPIRY_SECONDS=60
TRADE_AMOUNT=1.0

# Signal Engine Settings
MIN_CONFLUENCE_SCORE=0.75
MAX_TRADES_PER_HOUR=10
MAX_DAILY_LOSS_USD=20.0
CANDLE_INTERVAL_SECONDS=60
HISTORY_LENGTH=100
COOLDOWN_AFTER_LOSS_SECONDS=120

# Risk Management
DRY_RUN=true
MAX_OPEN_TRADES=1
MIN_BALANCE_MULTIPLIER=5
