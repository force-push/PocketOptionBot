# PocketOption Trading Bot Configuration
# Copy this file to .env and fill in your values

# ── CDP (legacy — kept for backward compat, not in live path) ──
CDP_URL=http://localhost:9222

# ── Trading Mode: DEMO or LIVE (MUST be DEMO by default) ──
TRADE_MODE=DEMO

# ── Asset & Timing Configuration ──
ASSET=EURUSD
EXPIRY_SECONDS=60
TRADE_AMOUNT=1.0

# ── Signal Engine Settings ──
# Confluence gates (both must pass for a trade):
#   Gate 1: min_signal_agreement — at least N signals must agree on same direction
#   Gate 2: min_confluence_score — weighted sum of signal confidences
MIN_SIGNAL_AGREEMENT=3              # Min signals agreeing on same direction (1–5)
MIN_CONFLUENCE_SCORE=0.20           # Min weighted confidence sum (0.0–1.0)
# TA candle resolution: deliberately decoupled from expiry. 5s gives 8 min of
# context for 100 candles; MACD/EMA need 25+ candles to warm up and detect trends.
CANDLE_INTERVAL_SECONDS=5           # Candle period in seconds (1, 5, 15, 30, 60, ...)
HISTORY_LENGTH=100                  # Number of candles to fetch per cycle
MAX_TRADES_PER_HOUR=10
MAX_DAILY_LOSS_USD=20.0
COOLDOWN_AFTER_LOSS_SECONDS=120
# Per-pair post-loss cooldown: after a pair loses, skip re-entering it for N
# seconds (the bot trades other pairs meanwhile — no idle time). Data showed
# trades <60s after a loss on a pair win only ~42%. 0 disables.
POST_LOSS_PAIR_COOLDOWN_SECONDS=60

# ── Risk Management ──
# DRY_RUN: when true, trades are logged but NOT executed (no real outcomes).
# Set to false to actually execute trades on the API and see real WIN/LOSS results.
# Trade outcomes are resolved asynchronously in the background (no blocking).
DRY_RUN=true
MAX_OPEN_TRADES=1
MIN_BALANCE_MULTIPLIER=5

# then paste the output string here.  Preferred over file session for servers/containers.
# Local only: leave SESSION_STRING blank and set your phone instead (session saved to file)

# ── PocketOption WebSocket API ──
# Capture the full 42["auth",{...}] string from the TRADING TERMINAL's WebSocket:
#   1. Open the trade terminal (e.g. /en/cabinet/demo-quick-high-low/) while logged in.
#   2. DevTools → Network → filter "Socket" → click the socket.io connection.
#   3. Messages tab → filter "auth" → copy the outgoing (↑) 42["auth",{...}] frame.
# It must contain "session" and "uid" fields (NOT "sessionToken" — that homepage
# frame is the wrong one). isDemo (0/1) inside the payload selects demo vs live.
# Example: 42["auth",{"session":"abc…","isDemo":1,"uid":123,"platform":1}]
PO_SSID=                              # Full 42["auth",{...}] string; isDemo encoded in it

# ── v2 Navigation & Decision Settings ──
STAKE_AMOUNT=3.00                  # Fixed stake per trade (USD)
DEFAULT_EXPIRY_SECONDS=30          # Trade expiry (snapped to nearest allowed)
# Shadow expiry experiment (signals loop, DEMO only): each real trade is
# replicated at these durations (shadow=True) to compare win rate across
# expiries. []=disabled. Excluded from tracker/risk and the UI history.
SHADOW_EXPIRY_SECONDS=[]
# 5s timeframe shadow track. When true, each cycle also fetches 5s candles and
# evaluates them with data/flip_levers_5s.json. Fires shadow trades at the listed
# expiries (shadow_kind="tf5s", DEMO only). false = off (no extra API load).
SHADOW_TF5S_ENABLED=false
SHADOW_TF5S_EXPIRY_SECONDS=[15,30]
# Time-of-day hour gating. false (default) = trade all hours. The static
# hour table didn't replicate across days (see SHADOW_TRADE_ANALYSIS.md).
TIME_OF_DAY_FILTER_ENABLED=false
# Shadow-trade blocked hours (signals loop, DEMO only): when true, hours
# blocked by the time-of-day filter still run signal scans, but trades are
# placed as shadows (shadow_kind="time_of_day") — collects 24h signal data
# without affecting the real strategy. false = blocked hours fully skipped.
SHADOW_TRADE_BLOCKED_HOURS=false
# Fade-rule shadows (DEMO only): >=N signals agree on a direction → shadow
# the OPPOSITE direction (shadow_kind="fade"). Exhaustion/mean-reversion
# experiment from SHADOW_TRADE_ANALYSIS.md. 0 = disabled.
SHADOW_FADE_MIN_AGREE=7
# ADX-regime shadows (DEMO only): ADX_DMI confidence >= this → shadow
# FOLLOWING the ADX direction (shadow_kind="adx_regime"). 0 = disabled.
SHADOW_ADX_REGIME_MIN_CONF=0.6
# Real OHLC (PO_DATA_SURFACE.md Step 2). false = stable flat get_candles() path (default).
# true = history() with genuine wicks — benefits HeikinAshi/ATR/Supertrend but adds
# WS latency and increases cycle-abort frequency. Enable at ≥120s expiry or when
# those signals demonstrate >54% accuracy lift over flat OHLC in shadow testing.
USE_REAL_OHLC=false
# Pair-selection win-rate gate. 0.0 DISABLES it (testing/capture — no trades).
# 2026-06-09 research: bot_win_rate>=0.80 -> 54.3% WR vs 41.7% at 0.7-0.8 (n=116).
# Recommended 0.80 for real runs. See docs/signal-strategy-research.md.
# Skip these pairs even when bot-rated highly (empirical losers, 2026-06-09):
BLOCKED_PAIRS=["EURUSD_otc","ETHUSD_otc","AUDCHF_otc","USDARS_otc","EURTRY_otc","USDPHP_otc","CHFNOK_otc"]
# Exact-match allowlist — empty = trade all active pairs ≥ MIN_PAYOUT_PCT.
ALLOWED_PAIRS=[]
# Pattern allowlist (looser, authoritative for poll loop + FocusSession when set;
# blocklist + FX-only still apply). e.g. trade USD/CNY/CNH/EUR crosses but exclude
# any GBP cross via lookahead: ^(?!.*GBP).*(USD|CNY|CNH|EUR)  — empty = off.
ALLOWED_PAIR_REGEX=
# ── Option A: Payout-First Signals Loop ──
MAX_PAIRS_PER_CYCLE=0              # 0 = evaluate all pairs ≥ floor each cycle

MIN_PAYOUT_PCT=92                  # Skip trade if PO payout < this % (0 = disabled)
MIN_EXPECTED_VALUE=0.0             # Min EV per trade (0=break-even gate, -0.05=warmup)
MIN_EV_SAMPLES=15                  # Trades needed per pair before EV gate activates
DECISIONS_LOG_PATH=data/decisions.jsonl

# Research/data-collection mode (DEMO ONLY; ignored in LIVE). When true, the bot
# stops blocking at the TA-agreement/EV/risk gates and trades anyway to record the
# outcome (tagged shadow=true + would_skip_reason), building an uncensored dataset.
# low_payout is still enforced; shadow trades do NOT feed the win-rate tracker.
SHADOW_RECORD_MODE=false

# ── TA Signal Parameters (per-indicator thresholds) ──
RSI_PERIOD=14                  # RSI lookback period
RSI_OVERSOLD=30                # RSI < this triggers CALL (mean reversion)
RSI_OVERBOUGHT=70              # RSI > this triggers PUT (mean reversion)
MACD_FAST=12                   # Fast EMA period for MACD
MACD_SLOW=26                   # Slow EMA period for MACD
MACD_SIGNAL_PERIOD=9           # Signal EMA period for MACD
EMA_FAST=9                     # Fast EMA period for EMA cross
EMA_SLOW=21                    # Slow EMA period for EMA cross
BOLLINGER_PERIOD=20            # SMA period for Bollinger Bands
BOLLINGER_STD=2.0              # Standard deviation for Bollinger Bands

# ── Dashboard (optional web UI; read-mostly, OFF by default) ──
# The bot emits live state (data/live_state.json + data/events.jsonl) only when
# DASHBOARD_ENABLED=true. The dashboard server (`python3 -m dashboard.server`) is
# a separate process. Keep the host on localhost; only expose it with a token.
DASHBOARD_ENABLED=false               # Bot writes live_state.json/events.jsonl when true
DASHBOARD_HOST=127.0.0.1              # Bind address — keep localhost
DASHBOARD_PORT=8787                  # Server port
DASHBOARD_TOKEN=                      # If set, required for POST /api/settings (X-Dashboard-Token or ?token=)
LIVE_STATE_PATH=data/live_state.json # Live snapshot path
EVENTS_LOG_PATH=data/events.jsonl    # Event stream path
