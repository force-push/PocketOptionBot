# ArgusSentinel — FUNCTIONAL CONFIG EXAMPLE
# Copy to .env.config and fill in values. No secrets here — those go in .env.secrets.

SHADOW_RECORD_MODE=false

# ── Trading Mode: DEMO or LIVE (MUST be DEMO by default) ──
TRADE_MODE=DEMO
DASHBOARD_ENABLED=false
DASHBOARD_HOST=127.0.0.1

# ── Risk Management ──
DRY_RUN=true
MAX_OPEN_TRADES=6
TRADE_STAGGER_SECONDS=0
MIN_BALANCE_MULTIPLIER=5
MAX_TRADES_PER_HOUR=240
MAX_DAILY_LOSS_USD=50.0
COOLDOWN_AFTER_LOSS_SECONDS=5
POST_LOSS_PAIR_COOLDOWN_SECONDS=30

# ── v2 Navigation & Decision Settings ──
STAKE_AMOUNT=1.0
DEFAULT_EXPIRY_SECONDS=5
SHADOW_EXPIRY_SECONDS=[]
SHADOW_TF5S_ENABLED=false
SHADOW_TF5S_EXPIRY_SECONDS=[15,30]

# ── SuperTrend-flip strategy ──
STRATEGY_MODE=flip
ALLOWED_PAIRS=[]
ALLOWED_PAIR_REGEX=
ONE_OPEN_TRADE_PER_PAIR=true
ST_PERIOD=10
ST_MULTIPLIER=3.0
FLIP_ADX_MIN=22
TREND_ADX_MIN=25
TREND_REQUIRE_ADX_RISING=true
TREND_ATR_DISTANCE_MIN=0.5
FLIP_WINDOW_BARS=3
CANDLE_FETCH_CONCURRENCY=3
STREAMING_ENABLED=false
FOCUS_SESSION_ENABLED=false
FOCUS_SESSION_TRADES=10
FOCUS_FX_ONLY=true
FOCUS_PAYOUT_FLOOR=90
FOCUS_MIN_TICK_RATE=2.0
STREAMING_PAIRS=["AUDUSD_otc","EURNZD_otc"]
SHADOW_ADX_REGIME_MIN_CONF=0.60
SHADOW_FLIP_SKIP_ENABLED=false
PAIR_SELECT_MIN_WIN_RATE=0.70
BLOCKED_PAIRS=[]
MIN_PAYOUT_PCT=92
PERF_COOLDOWN_MAX_WR=0.50
PERF_COOLDOWN_MIN_TRADES=5
PERF_COOLDOWN_HOURS=1.0
PREDICTION_SOURCE=signals
MAX_PAIRS_PER_CYCLE=0
MIN_EXPECTED_VALUE=0.0
MIN_EV_SAMPLES=10

# ── Martingale ──
MARTINGALE_ENABLED=false
MARTINGALE_MULTIPLIER=2.0
MARTINGALE_MAX_LEVEL=2
MARTINGALE_MIN_PAIR_WR=0.521
MARTINGALE_MIN_WR_SAMPLES=10
MARTINGALE_MIN_SESSION_TRADES=3
CLICK_TRADE_ANYWAY=false
DECISIONS_LOG_PATH=data/decisions.jsonl

# ── TA Signal Engine ──
USE_REAL_OHLC=false
CANDLE_INTERVAL_SECONDS=1
HISTORY_LENGTH=100
MIN_SIGNAL_AGREEMENT=2
MIN_CONFLUENCE_SCORE=0.20

# ── Legacy gate thresholds ──
MIN_CHANNEL_WIN_RATE=0.80
MIN_TRACKED_WIN_RATE=0.55
MIN_TRACKED_SAMPLES=20
SHADOW_TRADE_BLOCKED_HOURS=false
SHADOW_FADE_MIN_AGREE=0
